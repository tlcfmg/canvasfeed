# ─────────────────────────────────────────────────────────────────────────────
# canvasfeed — local configuration template
#
# Copy this file to .env, fill in your values, and keep .env off Git.
# The .gitignore already excludes .env for you.
# ─────────────────────────────────────────────────────────────────────────────

# Canvas access token
# How to get one:
#   1. Log in to Canvas and open Account (top-left avatar).
#   2. Go to Settings > Approved Integrations.
#   3. Click "New Access Token", give it a name, and copy the token.
# Note: the token is only shown once — save it here immediately.
CANVAS_ACCESS_TOKEN=paste-your-canvas-token-here

# Canvas base URL — change this if your institution uses a different domain
CANVAS_BASE_URL=https://canvas.uva.nl

# ─── LLM settings ────────────────────────────────────────────────────────────
# API key for the language model.
# If you are using the UvA AI Research Proxy, paste the key you received here.
LLM_API_KEY=paste-your-llm-api-key-here

# Leave these unchanged if you are using the UvA AI Research Proxy.
LLM_BASE_URL=https://ai-research-proxy.azurewebsites.net
LLM_MODEL=mistral-small-3.2
